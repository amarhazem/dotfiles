#!/usr/bin/env bash
{{- $nvmDefault := .versions.nvm -}}
{{- $nvmVersion := promptString (printf "Version NVM a installer (%s)" $nvmDefault) $nvmDefault -}}
# versions: nvm={{ $nvmVersion }}

set -euo pipefail

if [[ "$(uname -s)" != "Linux" ]]; then
  exit 0
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "==> curl unavailable; skipping user tools installation"
  exit 0
fi

export NVM_DIR="$HOME/.nvm"
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$HOME/.local/bin:$PNPM_HOME:$PATH"

if [[ ! -s "$NVM_DIR/nvm.sh" ]]; then
  echo "==> Installing NVM"

  curl -fsSL \
    "https://raw.githubusercontent.com/nvm-sh/nvm/v{{ $nvmVersion }}/install.sh" |
    PROFILE=/dev/null bash
fi

# shellcheck source=/dev/null
source "$NVM_DIR/nvm.sh"

echo "==> Installing the latest Node.js LTS"

nvm install --lts --latest-npm
nvm alias default 'lts/*'
nvm use default >/dev/null

echo "==> Enabling Corepack"

corepack enable

echo "==> Installing pnpm and Yarn"

corepack install --global pnpm@latest
corepack install --global yarn@stable

pnpm config set global-bin-dir "$PNPM_HOME"

echo "==> Installing Vercel CLI"

pnpm add --global --allow-build=esbuild vercel@latest

echo "==> User tools installed"

printf 'Corepack: %s\n' "$(corepack --version)"
printf 'Node.js:  %s\n' "$(node --version)"
printf 'npm:      %s\n' "$(npm --version)"
printf 'nvm:      %s\n' "$(nvm --version)"
printf 'pnpm:     %s\n' "$(pnpm --version)"
printf 'Yarn:     %s\n' "$(yarn --version)"
printf 'Vercel:   %s\n' "$(vercel --version)"
